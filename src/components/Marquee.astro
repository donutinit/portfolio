---
interface Props {
  variant?: 'default' | 'accent' | 'acid' | 'signal';
}
const { variant = 'default' } = Astro.props;

const bgClass = {
  default: 'bg-[var(--color-bg)] text-[var(--color-ink)]',
  accent: 'bg-[var(--color-accent)] text-[var(--color-bg)]',
  acid: 'bg-[var(--color-acid)] text-[var(--color-bg)]',
  signal: 'bg-[var(--color-signal)] text-[var(--color-bg)]',
}[variant];
---

<div class={`border-b rule overflow-hidden ${bgClass}`}>
  <div class="marquee-track flex font-mono text-[10px] md:text-xs uppercase tracking-[0.2em] py-2.5 md:py-3 whitespace-nowrap">
    {[0, 1].map(() => (
      <div class="flex shrink-0 items-center gap-5 md:gap-8 px-3 md:px-5">
        <slot />
      </div>
    ))}
  </div>
</div>
