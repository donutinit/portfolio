---
const path = Astro.url.pathname;
const isHome = path === '/';
const isAbout = path.startsWith('/about');
const isContact = path.startsWith('/contact');

const navClass = (active: boolean) =>
  active
    ? 'text-[var(--color-accent)]'
    : 'text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors';
---

<header class="sticky top-0 z-50 backdrop-blur-xl bg-[var(--color-bg)]/75 border-b rule">
  <div class="px-4 md:px-6 py-3 md:py-4 flex items-center justify-between font-mono text-[10px] md:text-xs uppercase tracking-[0.2em]">
    <a href="/" class="font-semibold flex items-center gap-2 hover:text-[var(--color-accent)] transition-colors">
      <span class="text-[var(--color-accent)] text-base leading-none">▮</span>
      <span>Von<span class="text-[var(--color-accent)]">.</span>Diego</span>
    </a>

    <nav class="flex items-center gap-4 md:gap-7">
      <a href="/" class={navClass(isHome)}>Work</a>
      <a href="/about" class={navClass(isAbout)}>About</a>
      <a href="/contact" class={navClass(isContact)}>Contact</a>
    </nav>
  </div>
</header>
