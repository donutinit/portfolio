---
const path = Astro.url.pathname;
const isHome = path === '/';
const isAbout = path.startsWith('/about');
const isContact = path.startsWith('/contact');

const navClass = (active: boolean) =>
  active
    ? 'text-[var(--color-accent)]'
    : 'text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors';
---

<header class="border-b rule">
  <div class="px-6 md:px-10 py-5 flex items-center justify-between font-mono text-xs uppercase tracking-[0.2em]">
    <a href="/" class="font-semibold hover:text-[var(--color-accent)] transition-colors">
      <span class="hidden sm:inline">█ </span>Donut Init
    </a>

    <nav class="flex items-center gap-6 md:gap-10">
      <a href="/" class={navClass(isHome)}>Work</a>
      <a href="/about" class={navClass(isAbout)}>About</a>
      <a href="/contact" class={navClass(isContact)}>Contact</a>
    </nav>
  </div>
</header>
