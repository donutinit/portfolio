---
const path = Astro.url.pathname;
const isHome = path === '/';
const isAbout = path.startsWith('/about');
const isContact = path.startsWith('/contact');

const navClass = (active: boolean) =>
  active
    ? 'text-[var(--color-acid)]'
    : 'text-[var(--color-ink)]/80 hover:text-[var(--color-acid)] transition-colors';
---

<header class="sticky top-0 z-50 backdrop-blur-xl bg-[var(--color-bg)]/82 border-b rule">
  <div class="px-3 md:px-6 py-3 md:py-4 flex items-center justify-between gap-3 font-mono text-[10px] md:text-xs uppercase tracking-[0.18em]">
    <a href="/" class="font-semibold flex items-center gap-2 hover:text-[var(--color-acid)] transition-colors min-w-0">
      <span class="text-[var(--color-accent)] text-base leading-none">▰</span>
      <span class="truncate">Von<span class="text-[var(--color-acid)]">.</span>Diego</span>
    </a>

    <p class="hidden lg:block text-[var(--color-muted)]">
      sistema visual / monterrey / producto final
    </p>

    <nav class="flex items-center gap-3 md:gap-6 shrink-0">
      <a href="/" class={navClass(isHome)}>Archivo</a>
      <a href="/about" class={navClass(isAbout)}>Manifiesto</a>
      <a href="/contact" class={navClass(isContact)}>Contacto</a>
    </nav>
  </div>
</header>
