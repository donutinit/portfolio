---

<BaseLayout title="" description="Von Diego — archivo en movimiento. Monterrey.">
  <a href="/obra" class="opening-skip">
    <span>saltar al índice</span>
    <span aria-hidden="true">→</span>
  </a>

  <button
    type="button"
    class="sonido"
    data-sonido
    data-on="true"
    aria-pressed="true"
    aria-label="Silenciar"
  >
    <span class="sonido-dot" aria-hidden="true"></span>
    <span data-sonido-label>sonido on</span>
  </button>

  <main class="reel" data-reel>
    {items.map((item, i) => {
      if (item.kind === 'final') {
        return (
          <section class="plate plate--final" data-plate={i}>
            <div class="plate-final-copy plate-fadein">
              <p class="plate-kicker">{item.code}</p>
              <h2 class="plate-final-title">
                <em>{item.line}</em> {item.lineEm}.
              </h2>
              <a href="/obra" class="plate-final-link">
                <span class="plate-final-link-rule" aria-hidden="true"></span>
                ver el índice
              </a>
            </div>
          </section>
        );
      }

      if (item.kind === 'grid') {
        const gridClass =
          item.photos.length >= 10 ? 'grid--dense' : item.photos.length === 8 ? 'grid--feature' : 'grid--six';
        const gridBase =
          item.title === 'monterrey,' ? 22.2
          : item.title === 'los' ? 22.6
          : item.photos.length >= 10 ? 19.8
          : item.photos.length === 8 ? 21.8
          : 22.8;

        return (
          <section class="plate plate--grid" data-plate={i}>
            <header class="grid-head">
              <p class="plate-code grid-code">
                <span>{item.code}</span>
                <span aria-hidden="true">·</span>
                <span>{item.caption}</span>
              </p>
              <h2 class="grid-title">
                {item.title} <em>{item.titleEm}</em>.
              </h2>
            </header>
            <div class={`grid ${gridClass}`}>
              {item.photos.map((p, j) => (
                <a
                  href={p.href}
                  class={`grid-cell ${photoClass(p)}`}
                  aria-label={p.alt}
                  style={`--ratio: ${(p.width / p.height).toFixed(6)}; --basis: ${((p.width / p.height) * gridBase).toFixed(3)}rem;`}
                >
                  <img
                    src={p.src}
                    alt={p.alt}
                    width={p.width}
                    height={p.height}
                    loading={i <= 1 && j < 3 ? 'eager' : 'lazy'}
                    decoding={i <= 1 && j < 3 ? 'sync' : 'async'}
                  />
                </a>
              ))}
            </div>
          </section>
        );
      }

      const compactClass =
        item.anchor.includes('entrevista-missael-vhs')
        || item.anchor.includes('parto')
        || item.anchor.includes('entrevista-beto')
          ? ' plate--compact'
          : '';

      return (
        <section class={`plate plate--video plate--aspect-${item.aspect.replace('/', '-')}${compactClass}`} data-plate={i}>
          <a class="plate-bed" href={item.anchor} aria-label={item.where}>
            <video
              data-plate-video
              autoplay
              loop
              playsinline
              preload={i === 0 ? 'auto' : 'metadata'}
              poster={item.poster}
              style={`aspect-ratio: ${item.aspect};`}
            >
              <source src={item.src} type="video/mp4" />
            </video>
          </a>

          <p class="plate-code">
            <span>{item.code}</span>
            <span aria-hidden="true">·</span>
            <span>{item.where}</span>
            <span aria-hidden="true">·</span>
            <span>vd / {item.year}</span>
            <span aria-hidden="true">·</span>
            <span>cinta · {item.aspect}</span>
          </p>

          <div class="plate-copy">
            <h2 class="plate-line">
              {item.line} <em>{item.lineEm}</em>.
            </h2>
          </div>

          {i === 0 && (
            <span class="plate-hint" aria-hidden="true">
              <span>desliza</span>
              <span class="plate-hint-arrow">↓</span>
            </span>
          )}
        </section>
      );
    })}
  </main>

  <script>
    const button = document.querySelector<HTMLButtonElement>('[data-sonido]');
    const label = document.querySelector<HTMLSpanElement>('[data-sonido-label]');
    const videos = Array.from(document.querySelectorAll<HTMLVideoElement>('[data-plate-video]'));

    if (button && label) {
      const state = { wantSound: true };

      const applyButton = () => {
        button.setAttribute('aria-pressed', String(state.wantSound));
        button.setAttribute('aria-label', state.wantSound ? 'Silenciar' : 'Activar sonido');
        button.dataset.on = String(state.wantSound);
        label.textContent = state.wantSound ? 'sonido on' : 'sonido off';
      };

      const isCurrentVideo = (v: HTMLVideoElement) => {
        const rect = v.getBoundingClientRect();
        const viewport = window.innerHeight || document.documentElement.clientHeight;
        const visible = Math.min(rect.bottom, viewport) - Math.max(rect.top, 0);
        return visible > Math.min(rect.height, viewport) * 0.35;
      };

      const playVideo = async (v: HTMLVideoElement) => {
        v.muted = !state.wantSound;
        if (state.wantSound) v.volume = 1;
        try {
          await v.play();
        } catch {}
      };

      const playbackObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const v = entry.target as HTMLVideoElement;
            if (entry.isIntersecting && entry.intersectionRatio > 0.5) {
              playVideo(v);
            } else {
              v.pause();
            }
          }
        },
        { threshold: [0, 0.5, 0.8] }
      );

      videos.forEach((v) => playbackObserver.observe(v));

      button.addEventListener('click', () => {
        state.wantSound = !state.wantSound;
        applyButton();
        videos.forEach((v) => {
          if (!v.paused) {
            v.muted = !state.wantSound;
            if (state.wantSound) v.play().catch(() => {});
          }
        });
      });

      const retrySound = () => {
        if (!state.wantSound) return;
        videos.forEach((v) => {
          v.muted = false;
          v.volume = 1;
          if (isCurrentVideo(v)) {
            v.play().catch(() => {});
          }
        });
      };
      window.addEventListener('pointerdown', retrySound, { once: true });
      window.addEventListener('keydown', retrySound, { once: true });
      window.addEventListener('scroll', retrySound, { once: true, passive: true });

      applyButton();
    }

    // fade-in copy on enter; auto-quiet after 10s of visible playback
    const plateNodes = document.querySelectorAll<HTMLElement>('[data-plate]');
    const quietTimers = new WeakMap<Element, number>();
    const QUIET_AFTER_MS = 10_000;

    const copyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const el = entry.target as HTMLElement;
          if (entry.isIntersecting && entry.intersectionRatio > 0.35) {
            el.classList.add('plate--visible');
            // quiet timer only on video plates
            if (el.classList.contains('plate--video') && !quietTimers.has(el)) {
              const t = window.setTimeout(() => {
                el.classList.add('plate--quiet');
                quietTimers.delete(el);
              }, QUIET_AFTER_MS);
              quietTimers.set(el, t);
            }
          } else {
            el.classList.remove('plate--visible', 'plate--quiet');
            const t = quietTimers.get(el);
            if (t !== undefined) {
              window.clearTimeout(t);
              quietTimers.delete(el);
            }
          }
        });
      },
      { threshold: [0.35] }
    );
    plateNodes.forEach((p) => copyObserver.observe(p));
  </script>
</BaseLayout>
