---
import BaseLayout from '../layouts/BaseLayout.astro';

const opening = {
  src: '/media/videos/entrevista-yolanda.mp4',
  poster: '/media/video-posters/entrevista-yolanda.jpg',
  kicker: 'monterrey · 26 · primer acto',
  line: 'el archivo se abre como un',
  lineEm: 'párpado',
  coords: '25.668 · −100.318',
  signature: 'vd / 26',
};
---

<BaseLayout title="" description="Von Diego — archivo en movimiento. Monterrey.">
  <section class="opening" aria-label="Apertura">
    <div class="opening-stage" aria-hidden="true">
      <video
        class="opening-still"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster={opening.poster}
      >
        <source src={opening.src} type="video/mp4" />
      </video>
    </div>

    <div class="opening-letterbox opening-letterbox--top"></div>
    <div class="opening-letterbox opening-letterbox--bottom"></div>

    <div class="opening-copy">
      <p class="opening-kicker opening-fadein">{opening.kicker}</p>
      <h1 class="opening-line opening-fadein--slow">
        {opening.line} <em>{opening.lineEm}</em>.
      </h1>
    </div>

    <div class="opening-foot opening-fadein--slow">
      <div>
        <span class="opening-foot-rule" aria-hidden="true"></span>
        <span>{opening.coords}</span>
      </div>
      <div>{opening.signature}</div>
    </div>

    <a href="/obra" class="entry opening-fadein--slow">índice</a>
  </section>
</BaseLayout>
