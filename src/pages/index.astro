---
import BaseLayout from '../layouts/BaseLayout.astro';

type VideoItem = {
  kind: 'video';
  code: string;
  where: string;
  year: string;
  src: string;
  poster: string;
  aspect: '16/9' | '4/3' | '9/16';
  line: string;
  lineEm: string;
  anchor: string;
};

type GridItem = {
  kind: 'grid';
  code: string;
  title: string;
  titleEm: string;
  caption: string;
  photos: Photo[];
};

type Photo = {
  src: string;
  alt: string;
  href: string;
  width: number;
  height: number;
};

type FinalItem = { kind: 'final'; code: string; line: string; lineEm: string };

type Item = VideoItem | GridItem | FinalItem;

const photo = (src: string, alt: string, href: string, width: number, height: number): Photo => ({
  src,
  alt,
  href,
  width,
  height,
});

const photoClass = (p: Photo) => {
  const r = p.width / p.height;
  if (r > 1.15) return 'grid-cell--wide';
  if (r >= 0.9) return 'grid-cell--square';
  if (r >= 0.74) return 'grid-cell--portrait';
  return 'grid-cell--tall';
};

