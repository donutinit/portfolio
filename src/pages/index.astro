---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allProjects = await getCollection('projects');
const projects = allProjects.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const typeLabel: Record<string, string> = {
  retrato: 'Retrato',
  evento: 'Evento',
  comercial: 'Comercial',
  personal: 'Obra personal',
  concierto: 'En vivo',
};

const totalPieces = projects.reduce((sum, p) => sum + p.data.photoCount, 0);
---

<BaseLayout>
  <section class="concept-hero concept-hero-direct">
    <div class="concept-opening-grid" aria-hidden="true">
      <span>000</span>
      <span>sin statement</span>
      <span>{String(totalPieces).padStart(3, '0')} piezas en fuga</span>
    </div>

    <div class="concept-title-block">
      <p class="micro-label">archivo visual / monterrey / {String(projects.length).padStart(2, '0')} expedientes / {String(totalPieces).padStart(3, '0')} piezas</p>
      <h1 class="glitch-head" data-text="Von Diego">Von Diego</h1>
    </div>

    <div class="concept-bottom-mark" aria-hidden="true">
      <span>archivo abajo</span>
      <span>↓</span>
    </div>
  </section>

  <section class="concept-statement">
    <p>
      Vive<br />
      Canta<br />
      Sueña
    </p>
    <p>
      Usando para ello el corazón
    </p>
  </section>

  <section class="concept-ledger">
    <div class="concept-ledger-head">
      <p class="micro-label text-[var(--color-muted)]">archivo</p>
      <h2 class="glitch-cut" data-text="Obra.">Obra.</h2>
      <p>{String(totalPieces).padStart(3, '0')} piezas registradas</p>
    </div>

    <div class="work-grid home-work-grid">
      {projects.map((p, i) => (
        <a
          href={`/work/${p.slug}`}
          class="work-card group"
          aria-label={`Abrir expediente: ${p.data.title}`}
        >
          <div class="work-media">
            <img
              src={p.data.poster}
              alt={p.data.title}
              class="card-hover"
              loading={i < 3 ? 'eager' : 'lazy'}
              decoding={i < 3 ? 'sync' : 'async'}
              fetchpriority={i === 0 ? 'high' : 'auto'}
            />
          </div>

          <div class="work-meta">
            <div class="work-index-line">
              <span>{String(i + 1).padStart(2, '0')}</span>
              <span>{typeLabel[p.data.type]}</span>
              <span>{p.data.year}</span>
              <span>{String(p.data.photoCount).padStart(2, '0')} piezas</span>
            </div>
            <h3 class="work-title">{p.data.title}</h3>
            {p.data.location && <p class="work-place">{p.data.location}</p>}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
