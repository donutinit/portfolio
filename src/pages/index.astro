---

<BaseLayout title="" description="Von Diego — archivo en movimiento. Monterrey.">
  <div class="ready-gate" data-ready-gate role="dialog" aria-modal="true" aria-labelledby="ready-title">
    <div class="ready-gate-inner">
      <p class="ready-gate-kicker">vd / archivo</p>
      <button id="ready-title" type="button" class="ready-gate-button" data-ready-button>
        estás listo?
      </button>
    </div>
  </div>

  <a href="/obra" class="opening-skip">
    <span>saltar al índice</span>
    <span aria-hidden="true">→</span>
  </a>

  <button
    type="button"
    class="sonido"
    data-sonido
    data-on="true"
    aria-pressed="true"
    aria-label="Silenciar"
  >
    <span class="sonido-dot" aria-hidden="true"></span>
    <span data-sonido-label>sonido on</span>
  </button>

  <main class="reel" data-reel>
    {items.map((item, i) => {
      if (item.kind === 'final') {
        return (
          <section class="plate plate--final" data-plate={i}>
            <div class="plate-final-copy plate-fadein">
              <p class="plate-kicker">{item.code}</p>
              <h2 class="plate-final-title">
                <em>{item.line}</em> {item.lineEm}.
              </h2>
              <a href="/obra" class="plate-final-link">
                <span class="plate-final-link-rule" aria-hidden="true"></span>
                ver el índice
              </a>
            </div>
          </section>
        );
      }

      if (item.kind === 'grid') {
        const gridClass =
          item.photos.length >= 10 ? 'grid--dense' : item.photos.length === 8 ? 'grid--feature' : 'grid--six';
        const gridBase =
          item.title === 'monterrey,' ? 22.2
          : item.title === 'los' ? 22.6
          : item.photos.length >= 10 ? 19.8
          : item.photos.length === 8 ? 21.8
          : 22.8;

        return (
          <section class="plate plate--grid" data-plate={i}>
            <header class="grid-head">
              <p class="plate-code grid-code">
                <span>{item.code}</span>
                <span aria-hidden="true">·</span>
                <span>{item.caption}</span>
              </p>
              <h2 class="grid-title">
                {item.title} <em>{item.titleEm}</em>.
              </h2>
            </header>
            <div class={`grid ${gridClass}`}>
              {item.photos.map((p, j) => (
                <a
                  href={p.href}
                  class={`grid-cell ${photoClass(p)}`}
                  aria-label={p.alt}
                  style={`--ratio: ${(p.width / p.height).toFixed(6)}; --basis: ${((p.width / p.height) * gridBase).toFixed(3)}rem;`}
                >
                  <img
                    src={p.src}
                    alt={p.alt}
                    width={p.width}
                    height={p.height}
                    loading={i <= 1 && j < 3 ? 'eager' : 'lazy'}
                    decoding={i <= 1 && j < 3 ? 'sync' : 'async'}
                  />
                </a>
              ))}
            </div>
          </section>
        );
      }

      const compactClass =
        item.anchor.includes('entrevista-missael-vhs')
        || item.anchor.includes('parto')
        || item.anchor.includes('entrevista-beto')
          ? ' plate--compact'
          : '';

      return (
        <section class={`plate plate--video plate--aspect-${item.aspect.replace('/', '-')}${compactClass}`} data-plate={i}>
          <a class="plate-bed" href={item.anchor} aria-label={item.where}>
            <video
              data-plate-video
              loop
              playsinline
              preload={i === 0 ? 'auto' : 'metadata'}
              poster={item.poster}
              style={`aspect-ratio: ${item.aspect};`}
            >
              <source src={item.src} type="video/mp4" />
            </video>
          </a>

          <p class="plate-code">
            <span>{item.code}</span>
            <span aria-hidden="true">·</span>
            <span>{item.where}</span>
            <span aria-hidden="true">·</span>
            <span>vd / {item.year}</span>
            <span aria-hidden="true">·</span>
            <span>cinta · {item.aspect}</span>
          </p>

          <div class="plate-copy">
            <h2 class="plate-line">
              {item.line} <em>{item.lineEm}</em>.
            </h2>
          </div>

          {i === 0 && (
            <span class="plate-hint" aria-hidden="true">
              <span>desliza</span>
              <span class="plate-hint-arrow">↓</span>
            </span>
          )}
        </section>
      );
    })}
  </main>

  <script>
    const readyGate = document.querySelector<HTMLElement>('[data-ready-gate]');
    const readyButton = document.querySelector<HTMLButtonElement>('[data-ready-button]');
    const button = document.querySelector<HTMLButtonElement>('[data-sonido]');
    const label = document.querySelector<HTMLSpanElement>('[data-sonido-label]');
    const videoPlates = Array.from(document.querySelectorAll<HTMLElement>('.plate--video'));
    const videos = videoPlates
      .map((plate) => plate.querySelector<HTMLVideoElement>('[data-plate-video]'))
      .filter((video): video is HTMLVideoElement => Boolean(video));

    if (readyGate) document.documentElement.style.overflow = 'hidden';

    if (button && label) {
      const state = { ready: false, wantSound: true, needsGesture: false };
      let playbackFrame = 0;

      const applyButton = () => {
        button.setAttribute('aria-pressed', String(state.wantSound));
        button.setAttribute('aria-label', state.wantSound ? 'Silenciar' : 'Activar sonido');
        button.dataset.on = String(state.wantSound);
        label.textContent = state.wantSound
          ? state.needsGesture
            ? 'toca sonido'
            : 'sonido on'
          : 'sonido off';
      };

      const visibleRatio = (el: HTMLElement) => {
        const rect = el.getBoundingClientRect();
        const viewportH = window.innerHeight || document.documentElement.clientHeight;
        const viewportW = window.innerWidth || document.documentElement.clientWidth;
        const visibleH = Math.min(rect.bottom, viewportH) - Math.max(rect.top, 0);
        const visibleW = Math.min(rect.right, viewportW) - Math.max(rect.left, 0);
        if (visibleH <= 0 || visibleW <= 0 || rect.height <= 0 || rect.width <= 0) return 0;
        return (visibleH * visibleW) / (rect.height * rect.width);
      };

      const currentVideo = () => {
        const viewportCenter = (window.innerHeight || document.documentElement.clientHeight) / 2;
        let selectedDistance = Number.POSITIVE_INFINITY;
        let selectedRatio = 0;
        let selectedVideo: HTMLVideoElement | null = null;

        videoPlates.forEach((plate) => {
          const video = plate.querySelector<HTMLVideoElement>('[data-plate-video]');
          if (!video) return;

          const ratio = visibleRatio(plate);
          if (ratio < 0.2) return;

          const rect = plate.getBoundingClientRect();
          const distance = Math.abs((rect.top + rect.bottom) / 2 - viewportCenter);
          if (!selectedVideo || ratio > selectedRatio + 0.12 || distance < selectedDistance) {
            selectedDistance = distance;
            selectedRatio = ratio;
            selectedVideo = video;
          }
        });

        return selectedVideo;
      };

      const playVideo = async (v: HTMLVideoElement, fromGesture = false) => {
        if (!state.ready) return;
        videos.forEach((video) => {
          if (video !== v) {
            video.pause();
            video.muted = true;
          }
        });
        v.muted = !state.wantSound;
        if (state.wantSound) v.volume = 1;
        try {
          await v.play();
          if (state.wantSound && !v.muted) {
            state.needsGesture = false;
            applyButton();
          }
        } catch {
          if (!state.wantSound || fromGesture) return;
          state.needsGesture = true;
          applyButton();
          v.muted = true;
          try { await v.play(); } catch {}
        }
      };

      const syncPlayback = (fromGesture = false) => {
        if (!state.ready) {
          videos.forEach((video) => video.pause());
          return;
        }

        const nextVideo = currentVideo();

        videos.forEach((video) => {
          if (video !== nextVideo) {
            video.pause();
            video.muted = true;
          }
        });

        if (nextVideo) playVideo(nextVideo, fromGesture);
      };

      const scheduleSync = () => {
        if (playbackFrame) return;
        playbackFrame = window.requestAnimationFrame(() => {
          playbackFrame = 0;
          syncPlayback();
        });
      };

      const playbackObserver = new IntersectionObserver(scheduleSync, {
        threshold: [0, 0.2, 0.45, 0.7, 1],
      });

      videoPlates.forEach((plate) => playbackObserver.observe(plate));
      videos.forEach((video) => {
        video.addEventListener('play', () => {
          videos.forEach((other) => {
            if (other !== video) {
              other.pause();
              other.muted = true;
            }
          });
        });
      });

      button.addEventListener('click', () => {
        state.wantSound = !state.wantSound;
        if (!state.wantSound) state.needsGesture = false;
        applyButton();
        syncPlayback(true);
      });

      const retrySound = () => {
        if (!state.ready || !state.wantSound) return;
        syncPlayback(true);
      };

      readyButton?.addEventListener('click', () => {
        state.ready = true;
        state.wantSound = true;
        state.needsGesture = false;
        readyGate?.setAttribute('data-hidden', 'true');
        readyGate?.setAttribute('aria-hidden', 'true');
        document.documentElement.style.overflow = '';
        applyButton();
        syncPlayback(true);
      });

      window.addEventListener('pointerdown', retrySound);
      window.addEventListener('touchend', retrySound, { passive: true });
      window.addEventListener('keydown', retrySound);
      window.addEventListener('scroll', scheduleSync, { passive: true });
      window.addEventListener('resize', scheduleSync, { passive: true });
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          videos.forEach((video) => video.pause());
        } else {
          scheduleSync();
        }
      });

      applyButton();
      videos.forEach((video) => video.pause());
    }

    // fade-in copy on enter; auto-quiet after 10s of visible playback
    const plateNodes = document.querySelectorAll<HTMLElement>('[data-plate]');
    const quietTimers = new WeakMap<Element, number>();
    const QUIET_AFTER_MS = 10_000;

    const copyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const el = entry.target as HTMLElement;
          if (entry.isIntersecting && entry.intersectionRatio > 0.35) {
            el.classList.add('plate--visible');
            // quiet timer only on video plates
            if (el.classList.contains('plate--video') && !quietTimers.has(el)) {
              const t = window.setTimeout(() => {
                el.classList.add('plate--quiet');
                quietTimers.delete(el);
              }, QUIET_AFTER_MS);
              quietTimers.set(el, t);
            }
          } else {
            el.classList.remove('plate--visible', 'plate--quiet');
            const t = quietTimers.get(el);
            if (t !== undefined) {
              window.clearTimeout(t);
              quietTimers.delete(el);
            }
          }
        });
      },
      { threshold: [0.35] }
    );
    plateNodes.forEach((p) => copyObserver.observe(p));
  </script>
</BaseLayout>
