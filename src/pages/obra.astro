---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="índice" description="Índice — Von Diego.">
  <section class="page">
    <p style="font-family: var(--f-mono); color: var(--polvo); font-size: 0.7rem; letter-spacing: 0.22em; text-transform: lowercase;">próximo acto</p>
    <h1 style="font-family: var(--f-serif); font-style: italic; font-size: clamp(2rem, 4vw, 4rem); line-height: 1.02; max-width: 22ch; margin-top: 1.4rem;">
      el índice se está revelando.
    </h1>
    <p style="font-family: var(--f-sans); color: var(--polvo); max-width: 46ch; margin-top: 1.4rem; line-height: 1.5;">
      esta página llega después del opening. de momento solo el primer acto se reveló.
    </p>
    <p style="margin-top: 3rem;">
      <a href="/" class="entry" style="position: static;">volver al opening</a>
    </p>
  </section>
</BaseLayout>
