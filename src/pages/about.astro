---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Manifiesto" description="Manifiesto de Von Diego — artista visual que convierte visiones en productos de calidad.">
  <section class="author-meta-row">
    <a href="/" class="hover:text-[var(--color-accent)] transition-colors">← archivo</a>
    <span>manifiesto / autor</span>
    <span>monterrey, mx</span>
  </section>

  <section class="author-statement">
    <div>
      <p class="micro-label text-[var(--color-accent)]">manifiesto</p>
      <h1 class="author-title">Producto visual con carácter.</h1>
    </div>
    <div class="author-statement-copy">
      <p>
        Soy un artista visual. Trabajo con ideas que necesitan una forma precisa,
        una estética propia y una salida final que se sostenga sola.
      </p>
      <p>
        No busco que todo se vea limpio. Busco que se vea verdadero para el proyecto:
        fino cuando debe ser fino, agresivo cuando debe pegar, raro cuando lo pide.
      </p>
    </div>
  </section>

  <section class="author-process">
    {[
      ['01', 'visión', 'lo que traes aunque todavía no tenga forma'],
      ['02', 'criterio', 'lo que se decide, se quita y se empuja'],
      ['03', 'obra', 'lo que queda listo para salir al mundo'],
    ].map(([num, title, copy]) => (
      <div>
        <span>{num}</span>
        <h3>{title}</h3>
        <p>{copy}</p>
      </div>
    ))}
  </section>

</BaseLayout>
