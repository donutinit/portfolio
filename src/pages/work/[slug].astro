---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  );

  return projects.map((project, i) => ({
    params: { slug: project.slug },
    props: {
      project,
      index: i,
      total: projects.length,
      prev: projects[i + 1] ?? null,
      next: projects[i - 1] ?? null,
    },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
  total: number;
  prev: CollectionEntry<'projects'> | null;
  next: CollectionEntry<'projects'> | null;
}

const { project, index, total, prev, next } = Astro.props;
const { Content } = await project.render();

const photos = Array.from({ length: project.data.photoCount }, (_, i) => ({
  src: `${project.data.photosDir}${project.data.photosPrefix}-${String(i + 1).padStart(2, '0')}.jpg`,
  name: `${project.data.photosPrefix}-${String(i + 1).padStart(2, '0')}.jpg`,
  index: i + 1,
}));

const typeLabel: Record<string, string> = {
  retrato: 'Retrato',
  evento: 'Evento',
  comercial: 'Comercial',
  personal: 'Obra personal',
  concierto: 'En vivo',
};
---

<BaseLayout
  title={project.data.title}
  description={`${project.data.title} — expediente visual de Von Diego, ${typeLabel[project.data.type]}, ${project.data.year}.`}
>
  <section class="author-meta-row">
    <a href="/" class="hover:text-[var(--color-acid)] transition-colors">
      ← archivo
    </a>
    <span>
      expediente <span class="text-[var(--color-acid)]">{String(index + 1).padStart(2, '0')}</span>
      / {String(total).padStart(2, '0')}
    </span>
  </section>

  <section class="project-author-hero project-author-hero--text">
    <div class="project-author-copy">
      <p class="micro-label text-[var(--color-accent)]">expediente visual</p>
      <h1 class="author-title project-title">{project.data.title}</h1>
    </div>

    <div class="project-register">
      <p class="micro-label text-[var(--color-muted)]">registro</p>
      <dl class="project-facts">
        <div>
          <dt>tipo</dt>
          <dd>{typeLabel[project.data.type]}</dd>
        </div>
        <div>
          <dt>año</dt>
          <dd>{project.data.year}</dd>
        </div>
        {project.data.location && (
          <div>
            <dt>lugar</dt>
            <dd>{project.data.location}</dd>
          </div>
        )}
        {project.data.client && (
          <div>
            <dt>cliente</dt>
            <dd>{project.data.client}</dd>
          </div>
        )}
        <div>
          <dt>piezas</dt>
          <dd>{String(project.data.photoCount).padStart(2, '0')}</dd>
        </div>
      </dl>
      <p class="project-register-note">
        La imagen empieza abajo. Esta entrada solo deja las coordenadas.
      </p>
    </div>
  </section>

  <section class="project-essay">
    <div>
      <p class="micro-label text-[var(--color-accent)]">lectura</p>
      <h2>Una pieza no se explica: se sostiene.</h2>
    </div>
    <div class="prose-content">
      <Content />
    </div>
  </section>

  <section class="author-work">
    <div class="author-section-head">
      <p class="micro-label text-[var(--color-accent)]">piezas</p>
      <h2>Archivo abierto</h2>
      <p>
        {String(photos.length).padStart(2, '0')} archivos / {project.data.photosPrefix}
      </p>
    </div>

    <div class="contact-sheet">
      {photos.map((photo, i) => (
        <figure class="group">
          <button
            type="button"
            class="lightbox-trigger"
            data-lightbox-src={photo.src}
            data-lightbox-alt={`${project.data.title} — pieza ${photo.index}`}
            aria-label={`Abrir ${project.data.title}, pieza ${photo.index}, en pantalla completa`}
          >
            <img
              src={photo.src}
              alt={`${project.data.title} — pieza ${photo.index}`}
              class="card-hover"
              loading={i < 4 ? 'eager' : 'lazy'}
              decoding={i < 4 ? 'sync' : 'async'}
            />
          </button>
          <figcaption class="gallery-caption">
            {String(photo.index).padStart(2, '0')} / {String(photos.length).padStart(2, '0')}
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <nav class="project-nav">
    {prev ? (
      <a href={`/work/${prev.slug}`} class="group">
        <p class="micro-label text-[var(--color-muted)] mb-3 group-hover:text-[var(--color-accent)] transition-colors">
          ← anterior
        </p>
        <p class="group-hover:text-[var(--color-accent)] transition-colors">
          {prev.data.title}
        </p>
      </a>
    ) : <div />}

    {next ? (
      <a href={`/work/${next.slug}`} class="group md:text-right">
        <p class="micro-label text-[var(--color-muted)] mb-3 group-hover:text-[var(--color-accent)] transition-colors">
          siguiente →
        </p>
        <p class="group-hover:text-[var(--color-accent)] transition-colors">
          {next.data.title}
        </p>
      </a>
    ) : <div />}
  </nav>

  <div class="lightbox-overlay" data-lightbox-overlay aria-hidden="true">
    <button type="button" class="lightbox-close" data-lightbox-close aria-label="Cerrar imagen">
      ×
    </button>
    <button type="button" class="lightbox-nav lightbox-prev" data-lightbox-prev aria-label="Imagen anterior">
      ←
    </button>
    <img class="lightbox-image" data-lightbox-image alt="" />
    <button type="button" class="lightbox-nav lightbox-next" data-lightbox-next aria-label="Imagen siguiente">
      →
    </button>
  </div>

  <script>
    const overlay = document.querySelector('[data-lightbox-overlay]');
    const image = document.querySelector('[data-lightbox-image]');
    const closeButton = document.querySelector('[data-lightbox-close]');
    const prevButton = document.querySelector('[data-lightbox-prev]');
    const nextButton = document.querySelector('[data-lightbox-next]');
    const triggers = Array.from(document.querySelectorAll('[data-lightbox-src]'));
    let activeIndex = -1;

    const showLightboxImage = (index: number) => {
      if (!(overlay instanceof HTMLElement) || !(image instanceof HTMLImageElement)) return;
      const trigger = triggers[index];
      if (!(trigger instanceof HTMLElement)) return;

      const src = trigger.dataset.lightboxSrc;
      if (!src) return;

      activeIndex = index;
      image.src = src;
      image.alt = trigger.dataset.lightboxAlt ?? '';
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';
    };

    const moveLightbox = (direction: number) => {
      if (activeIndex < 0 || triggers.length === 0) return;
      const nextIndex = (activeIndex + direction + triggers.length) % triggers.length;
      showLightboxImage(nextIndex);
    };

    const closeLightbox = () => {
      if (!(overlay instanceof HTMLElement) || !(image instanceof HTMLImageElement)) return;
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      image.removeAttribute('src');
      image.alt = '';
      activeIndex = -1;
      document.documentElement.style.overflow = '';
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => {
        showLightboxImage(index);
        if (closeButton instanceof HTMLElement) closeButton.focus();
      });
    });

    overlay?.addEventListener('click', (event) => {
      if (event.target === overlay) closeLightbox();
    });

    closeButton?.addEventListener('click', closeLightbox);
    prevButton?.addEventListener('click', () => moveLightbox(-1));
    nextButton?.addEventListener('click', () => moveLightbox(1));

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeLightbox();
      if (event.key === 'ArrowLeft') moveLightbox(-1);
      if (event.key === 'ArrowRight') moveLightbox(1);
    });
  </script>
</BaseLayout>
