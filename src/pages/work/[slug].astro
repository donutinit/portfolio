---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  );

  return projects.map((project, i) => ({
    params: { slug: project.slug },
    props: {
      project,
      index: i,
      total: projects.length,
      prev: projects[i + 1] ?? null,
      next: projects[i - 1] ?? null,
    },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
  total: number;
  prev: CollectionEntry<'projects'> | null;
  next: CollectionEntry<'projects'> | null;
}

const { project, index, total, prev, next } = Astro.props;
const { Content } = await project.render();

const photos = Array.from({ length: project.data.photoCount }, (_, i) => ({
  src: `${project.data.photosDir}${project.data.photosPrefix}-${String(i + 1).padStart(2, '0')}.jpg`,
  name: `${project.data.photosPrefix}-${String(i + 1).padStart(2, '0')}.jpg`,
  index: i + 1,
}));

const typeLabel: Record<string, string> = {
  retrato: 'Retrato',
  evento: 'Evento',
  comercial: 'Comercial',
  personal: 'Personal',
  concierto: 'Concierto',
};
---

<BaseLayout
  title={project.data.title}
  description={`${project.data.title} — ${typeLabel[project.data.type]}, ${project.data.year}`}
>
  <!-- breadcrumb -->
  <section class="border-b rule px-4 md:px-6 py-3 font-mono text-[10px] md:text-xs uppercase tracking-[0.2em] flex items-baseline justify-between gap-3">
    <a href="/" class="hover:text-[var(--color-accent)] transition-colors">
      ← index
    </a>
    <span class="text-[var(--color-muted)]">
      <span class="text-[var(--color-accent)]">{String(index + 1).padStart(2, '0')}</span>
      <span class="mx-1">/</span>
      {String(total).padStart(2, '0')}
    </span>
  </section>

  <!-- project header -->
  <section class="px-4 md:px-6 pt-8 md:pt-14 pb-10 md:pb-16 border-b rule">
    <p class="font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-accent)] mb-3 md:mb-5">
      {typeLabel[project.data.type]} <span class="text-[var(--color-muted)]">·</span> {project.data.year}
    </p>

    <h1 class="text-5xl sm:text-6xl md:text-8xl lg:text-[10rem] font-medium tracking-tighter leading-[0.85] mb-8 md:mb-14">
      {project.data.title}
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <div class="md:col-span-2 text-base md:text-lg leading-relaxed text-[var(--color-ink)]/85 space-y-4 prose-content">
        <Content />
      </div>

      <aside class="font-mono text-xs uppercase tracking-[0.2em] grid grid-cols-2 md:grid-cols-1 gap-4 md:gap-3 content-start md:border-l border-[var(--color-rule)] md:pl-6">
        {project.data.location && (
          <div>
            <p class="text-[var(--color-muted)]/60 mb-1">location</p>
            <p class="text-[var(--color-ink)]">{project.data.location}</p>
          </div>
        )}
        {project.data.client && (
          <div>
            <p class="text-[var(--color-muted)]/60 mb-1">client</p>
            <p class="text-[var(--color-ink)]">{project.data.client}</p>
          </div>
        )}
        <div>
          <p class="text-[var(--color-muted)]/60 mb-1">year</p>
          <p class="text-[var(--color-ink)]">{project.data.year}</p>
        </div>
        <div>
          <p class="text-[var(--color-muted)]/60 mb-1">photos</p>
          <p class="text-[var(--color-ink)]">[{String(project.data.photoCount).padStart(2, '0')}]</p>
        </div>
      </aside>
    </div>
  </section>

  <!-- masonry gallery -->
  <section class="px-3 md:px-5 py-5 md:py-8">
    <div class="columns-2 md:columns-3 gap-3 md:gap-4 space-y-3 md:space-y-4 [&>figure]:break-inside-avoid">
      {photos.map((photo, i) => (
        <figure>
          <div class="bg-[var(--color-rule)] overflow-hidden">
            <img
              src={photo.src}
              alt={`${project.data.title} — ${photo.index}`}
              class="w-full h-auto"
              loading={i < 4 ? 'eager' : 'lazy'}
              decoding={i < 4 ? 'sync' : 'async'}
            />
          </div>
          <figcaption class="font-mono text-[9px] md:text-[10px] uppercase tracking-[0.2em] text-[var(--color-muted)] mt-1.5 flex justify-between gap-2">
            <span class="truncate">{photo.name}</span>
            <span class="shrink-0">[{String(photo.index).padStart(2, '0')}/{String(photos.length).padStart(2, '0')}]</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- prev/next -->
  <nav class="px-4 md:px-6 py-10 md:py-14 grid grid-cols-2 gap-4 border-t rule">
    {prev ? (
      <a href={`/work/${prev.slug}`} class="group">
        <p class="font-mono text-[10px] md:text-xs uppercase tracking-[0.25em] text-[var(--color-muted)] mb-2 md:mb-3 group-hover:text-[var(--color-accent)] transition-colors">
          ← prev
        </p>
        <p class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-medium tracking-tight group-hover:text-[var(--color-accent)] transition-colors leading-tight">
          {prev.data.title}
        </p>
      </a>
    ) : <div />}

    {next ? (
      <a href={`/work/${next.slug}`} class="group text-right">
        <p class="font-mono text-[10px] md:text-xs uppercase tracking-[0.25em] text-[var(--color-muted)] mb-2 md:mb-3 group-hover:text-[var(--color-accent)] transition-colors">
          next →
        </p>
        <p class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-medium tracking-tight group-hover:text-[var(--color-accent)] transition-colors leading-tight">
          {next.data.title}
        </p>
      </a>
    ) : <div />}
  </nav>
</BaseLayout>
