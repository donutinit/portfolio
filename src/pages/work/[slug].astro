---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  );

  return projects.map((project, i) => ({
    params: { slug: project.slug },
    props: {
      project,
      index: i,
      total: projects.length,
      prev: projects[i + 1] ?? null,
      next: projects[i - 1] ?? null,
    },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
  total: number;
  prev: CollectionEntry<'projects'> | null;
  next: CollectionEntry<'projects'> | null;
}

const { project, index, total, prev, next } = Astro.props;
const { Content } = await project.render();

const photos = Array.from({ length: project.data.photoCount }, (_, i) => ({
  src: `${project.data.photosDir}${project.data.photosPrefix}-${String(i + 1).padStart(2, '0')}.jpg`,
  name: `${project.data.photosPrefix}-${String(i + 1).padStart(2, '0')}.jpg`,
  index: i + 1,
}));

const typeLabel: Record<string, string> = {
  retrato: 'Retrato',
  evento: 'Evento',
  comercial: 'Comercial',
  personal: 'Personal',
  concierto: 'Concierto',
};
---

<BaseLayout title={project.data.title} description={`${project.data.title} — ${typeLabel[project.data.type]}, ${project.data.year}`}>
  <!-- Header -->
  <section class="px-6 md:px-10 pt-12 md:pt-20 pb-16 md:pb-24 border-b rule">
    <div class="flex items-baseline justify-between mb-12 md:mb-16 font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-muted)]">
      <a href="/" class="hover:text-[var(--color-accent)] transition-colors">← index</a>
      <p>{String(index + 1).padStart(2, '0')} / {String(total).padStart(2, '0')}</p>
    </div>

    <h1 class="text-6xl md:text-9xl font-medium tracking-tighter leading-[0.9] mb-8 md:mb-12">
      {project.data.title}
    </h1>

    <div class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-muted)] mb-10 md:mb-14">
      <span>{typeLabel[project.data.type]}</span>
      <span>·</span>
      <span>{project.data.year}</span>
      {project.data.location && (
        <>
          <span>·</span>
          <span>{project.data.location}</span>
        </>
      )}
      {project.data.client && (
        <>
          <span>·</span>
          <span>Cliente: {project.data.client}</span>
        </>
      )}
      <span>·</span>
      <span>[{project.data.photoCount} fotos]</span>
    </div>

    <div class="max-w-3xl text-lg md:text-xl leading-relaxed text-[var(--color-ink)]/90 space-y-4">
      <Content />
    </div>
  </section>

  <!-- Gallery -->
  <section>
    {photos.map((photo, i) => (
      <figure class="border-b rule">
        <img
          src={photo.src}
          alt={`${project.data.title} — ${photo.index}`}
          class="w-full h-auto"
          loading={i < 2 ? 'eager' : 'lazy'}
          decoding={i < 2 ? 'sync' : 'async'}
        />
        <figcaption class="px-6 md:px-10 py-4 font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-muted)] flex justify-between items-baseline">
          <span>{photo.name}</span>
          <span>{String(photo.index).padStart(2, '0')} / {String(photos.length).padStart(2, '0')}</span>
        </figcaption>
      </figure>
    ))}
  </section>

  <!-- Footer nav -->
  <nav class="px-6 md:px-10 py-12 md:py-16 grid grid-cols-2 gap-6 border-b rule">
    {prev ? (
      <a href={`/work/${prev.slug}`} class="group">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-muted)] mb-3">
          ← Anterior
        </p>
        <p class="text-2xl md:text-3xl font-medium tracking-tight group-hover:text-[var(--color-accent)] transition-colors">
          {prev.data.title}
        </p>
      </a>
    ) : <div />}

    {next ? (
      <a href={`/work/${next.slug}`} class="group text-right">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-muted)] mb-3">
          Siguiente →
        </p>
        <p class="text-2xl md:text-3xl font-medium tracking-tight group-hover:text-[var(--color-accent)] transition-colors">
          {next.data.title}
        </p>
      </a>
    ) : <div />}
  </nav>
</BaseLayout>
