---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { videos, youtubeFeature, kindLabel } from '../../data/videos';

const totalPlates = videos.length;
const lede =
  'Doce piezas que no caben en una foto. Entrevistas que se hicieron en la sala de los míos, comerciales que tuvieron que firmarse a mano y un par de cosas que se quedaron por dentro. Cada plate se imprime con su propio aire.';
---

<BaseLayout
  title="Proyección"
  description="Catálogo en movimiento — entrevistas, comerciales y obra personal de Von Diego."
>
  <section class="author-meta-row">
    <a href="/" class="hover:text-[var(--color-accent)] transition-colors">← archivo</a>
    <span>proyección / sala oscura</span>
    <span>{String(totalPlates).padStart(2, '0')} plates · 01 muestra</span>
  </section>

  <section class="cinta-hero">
    <div class="cinta-hero-mark" aria-hidden="true">
      <span>n.º 01</span>
      <span>volumen único</span>
      <span>monterrey · {new Date().getFullYear()}</span>
    </div>
    <h1 class="cinta-hero-title" aria-label="Proyección">
      <span class="glitch-cut" data-text="Pro">Pro</span>
      <span class="glitch-cut" data-text="yec">yec</span>
      <span class="glitch-cut" data-text="ción.">ción.</span>
    </h1>
    <p class="cinta-hero-lede">{lede}</p>
    <div class="cinta-hero-bottom" aria-hidden="true">
      <span>↓ pliego 01</span>
      <span class="cinta-hero-ticker">— rebobina lento — rebobina lento — rebobina lento — rebobina lento —</span>
    </div>
  </section>

  <section class="cinta-plates">
    {videos.map((v, i) => {
      const orientation = i % 2 === 0 ? 'left' : 'right';
      const plate = String(i + 1).padStart(2, '0');
      return (
        <article class={`plate plate--${orientation} plate--${v.aspect.replace('/', '-')}`}>
          <a class="plate-media" href={`/video/${v.slug}`} aria-label={`Abrir ${v.title}`}>
            <img
              src={v.poster}
              alt={v.title}
              loading={i < 2 ? 'eager' : 'lazy'}
              decoding={i < 2 ? 'sync' : 'async'}
            />
          </a>
          <div class="plate-copy">
            <p class="plate-index">
              <span>plate {plate}</span>
              <span>/ {String(totalPlates).padStart(2, '0')}</span>
            </p>
            <h2 class="plate-title">
              <a href={`/video/${v.slug}`}>{v.title}</a>
            </h2>
            {v.caption && <p class="plate-caption">«{v.caption}»</p>}
            <dl class="plate-facts">
              <div><dt>cinta</dt><dd>{kindLabel[v.kind]}</dd></div>
              <div><dt>año</dt><dd>{v.year}</dd></div>
              <div><dt>corre</dt><dd>{v.durationLabel}</dd></div>
              <div><dt>cuadro</dt><dd>{v.aspect}</dd></div>
            </dl>
            <a href={`/video/${v.slug}`} class="plate-cta">abrir pliego ↗</a>
          </div>
        </article>
      );
    })}
  </section>

  <section class="cinta-channel" aria-labelledby="cinta-channel-title">
    <div class="cinta-channel-meta">
      <p class="micro-label text-[var(--color-accent)]">muestra del canal</p>
      <h2 id="cinta-channel-title" class="cinta-channel-title">
        <span class="glitch-cut" data-text="Salido del">Salido del</span><br />
        <span class="glitch-cut" data-text="archivo público.">archivo público.</span>
      </h2>
      <p>{youtubeFeature.caption}</p>
      <a href={youtubeFeature.url} target="_blank" rel="noopener" class="cinta-channel-cta">
        ver en youtube ↗
      </a>
    </div>
    <a
      class="cinta-channel-frame"
      href={youtubeFeature.url}
      target="_blank"
      rel="noopener"
      aria-label="Abrir muestra en YouTube"
    >
      <span class="cinta-channel-tape">YT/001 · canal · von diego</span>
      <div class="cinta-channel-screen">
        <iframe
          src={`https://www.youtube.com/embed/${youtubeFeature.id}?rel=0&modestbranding=1`}
          title={youtubeFeature.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
      <span class="cinta-channel-footer">
        <span>REC ●</span>
        <span>von diego — canal abierto</span>
        <span>↗</span>
      </span>
    </a>
  </section>
</BaseLayout>
