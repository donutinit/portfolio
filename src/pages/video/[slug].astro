---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { videos, kindLabel } from '../../data/videos';

export async function getStaticPaths() {
  return videos.map((v, i) => ({
    params: { slug: v.slug },
    props: {
      video: v,
      index: i,
      total: videos.length,
      prev: videos[i - 1] ?? null,
      next: videos[i + 1] ?? null,
    },
  }));
}

const { video, index, total, prev, next } = Astro.props;
const plate = String(index + 1).padStart(2, '0');
const totalLabel = String(total).padStart(2, '0');
const aspectClass = `cine--${video.aspect.replace('/', '-')}`;
const aspectStyle = `--cine-aspect: ${video.aspect};`;
const formattedTitle = video.title.toLowerCase();
---

<BaseLayout
  title={video.title}
  description={video.caption ?? `${video.title} — pieza de video del archivo de Von Diego.`}
>
  <a href="/obra" class="opening-skip">
    <span>volver al índice</span>
    <span aria-hidden="true">↗</span>
  </a>

  <main class={`cine ${aspectClass}`} style={aspectStyle}>
    <header class="cine-rail">
      <p>
        <span class="text-mid">{plate}</span>
        <span aria-hidden="true"> / </span>
        <span>{totalLabel}</span>
      </p>
      <p>{video.tape ?? kindLabel[video.kind]}</p>
      <p>{kindLabel[video.kind]} · {video.year} · {video.durationLabel}</p>
    </header>

    <section class="cine-stage">
      <div class="cine-frame">
        <video
          autoplay
          controls
          playsinline
          preload="metadata"
          poster={video.poster}
        >
          <source src={video.src} type="video/mp4" />
          Tu navegador no puede reproducir esto.
        </video>
      </div>
    </section>

    <section class="cine-meta">
      <div class="cine-meta-main">
        <p class="cine-kicker">{video.tape ?? 'pieza · archivo'}</p>
        <h1 class="cine-title"><em>{formattedTitle.split(' — ')[0]}</em>{formattedTitle.includes(' — ') ? ` — ${formattedTitle.split(' — ')[1]}` : ''}.</h1>
        {video.caption && <p class="cine-caption">«{video.caption}»</p>}
      </div>

      <aside class="cine-register">
        <p class="cine-kicker">registro</p>
        <dl class="cine-facts">
          <div><dt>tipo</dt><dd>{kindLabel[video.kind]}</dd></div>
          <div><dt>año</dt><dd>{video.year}</dd></div>
          <div><dt>corre</dt><dd>{video.durationLabel}</dd></div>
          <div><dt>cuadro</dt><dd>{video.aspect}</dd></div>
          <div><dt>formato</dt><dd>mp4 · h264 · aac</dd></div>
        </dl>
      </aside>
    </section>

    <nav class="cine-nav">
      {prev ? (
        <a href={`/video/${prev.slug}`} class="cine-nav-link group">
          <span class="cine-kicker">← anterior</span>
          <span class="cine-nav-title">{prev.title.toLowerCase()}</span>
        </a>
      ) : <div />}

      {next ? (
        <a href={`/video/${next.slug}`} class="cine-nav-link cine-nav-link--next group">
          <span class="cine-kicker">siguiente →</span>
          <span class="cine-nav-title">{next.title.toLowerCase()}</span>
        </a>
      ) : <div />}
    </nav>
  </main>
</BaseLayout>
