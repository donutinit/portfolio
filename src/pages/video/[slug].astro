---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { videos, kindLabel } from '../../data/videos';

export async function getStaticPaths() {
  return videos.map((v, i) => ({
    params: { slug: v.slug },
    props: {
      video: v,
      index: i,
      total: videos.length,
      prev: videos[i - 1] ?? null,
      next: videos[i + 1] ?? null,
    },
  }));
}

const { video, index, total, prev, next } = Astro.props;
const plate = String(index + 1).padStart(2, '0');
const totalLabel = String(total).padStart(2, '0');
---

<BaseLayout
  title={video.title}
  description={video.caption ?? `${video.title} — pieza de video del archivo de Von Diego.`}
>
  <section class="theater-rail" aria-hidden="true">
    <a href="/video" class="theater-rail-back">← archivo de video</a>
    <span class="theater-rail-mark">
      <span class="text-[var(--color-acid)]">{plate}</span> / {totalLabel} · {video.tape ?? kindLabel[video.kind]}
    </span>
    <span class="theater-rail-mark">{kindLabel[video.kind]} · {video.year} · {video.durationLabel}</span>
  </section>

  <section class={`theater theater--${video.aspect.replace('/', '-')}`}>
    <div class="theater-frame">
      <video
        controls
        playsinline
        preload="metadata"
        poster={video.poster}
      >
        <source src={video.src} type="video/mp4" />
        Tu navegador no puede reproducir esto.
      </video>
    </div>
  </section>

  <section class="theater-meta">
    <div class="theater-meta-main">
      <p class="micro-label text-[var(--color-accent)]">{video.tape ?? 'pieza · archivo'}</p>
      <h1 class="theater-title">{video.title}</h1>
      {video.caption && <p class="theater-caption">«{video.caption}»</p>}
    </div>

    <aside class="theater-register">
      <p class="micro-label text-[var(--color-muted)]">registro</p>
      <dl class="theater-facts">
        <div><dt>tipo</dt><dd>{kindLabel[video.kind]}</dd></div>
        <div><dt>año</dt><dd>{video.year}</dd></div>
        <div><dt>corre</dt><dd>{video.durationLabel}</dd></div>
        <div><dt>cuadro</dt><dd>{video.aspect}</dd></div>
        <div><dt>formato</dt><dd>mp4 · h264 · aac</dd></div>
      </dl>
    </aside>
  </section>

  <nav class="theater-nav">
    {prev ? (
      <a href={`/video/${prev.slug}`} class="theater-nav-link group">
        <span class="micro-label">← anterior</span>
        <span class="theater-nav-title">{prev.title}</span>
      </a>
    ) : <div />}

    {next ? (
      <a href={`/video/${next.slug}`} class="theater-nav-link theater-nav-link--next group">
        <span class="micro-label">siguiente →</span>
        <span class="theater-nav-title">{next.title}</span>
      </a>
    ) : <div />}
  </nav>
</BaseLayout>
