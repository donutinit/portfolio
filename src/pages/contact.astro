---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contacto comercial y profesional para Donut Init.">
  <section class="px-6 md:px-10 py-16 md:py-24 max-w-4xl">
    <p class="font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-muted)] mb-6">
      Contact / 02
    </p>
    <h1 class="text-6xl md:text-8xl font-medium tracking-tighter leading-[0.9] mb-12 md:mb-16">
      Hablemos.
    </h1>

    <div class="space-y-12 md:space-y-16">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-muted)] mb-3">
          Comercial / proyectos
        </p>
        <a
          href="mailto:contacto@vondiego.com"
          class="block text-3xl md:text-5xl font-medium tracking-tight hover:text-[var(--color-accent)] transition-colors"
        >
          contacto@vondiego.com
        </a>
      </div>

      <div class="pt-10 border-t rule">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-muted)] mb-3">
          Instagram
        </p>
        <a
          href="https://instagram.com/donutinit"
          target="_blank"
          rel="noopener"
          class="block text-3xl md:text-5xl font-medium tracking-tight hover:text-[var(--color-accent)] transition-colors"
        >
          @donutinit ↗
        </a>
      </div>

      <div class="pt-10 border-t rule grid grid-cols-1 md:grid-cols-2 gap-8 font-mono text-xs">
        <div>
          <p class="uppercase tracking-[0.25em] text-[var(--color-muted)] mb-3">Tiempo de respuesta</p>
          <p class="text-sm leading-relaxed">
            ~24 horas en días hábiles.<br />
            Si es urgente, mándamelo por DM.
          </p>
        </div>
        <div>
          <p class="uppercase tracking-[0.25em] text-[var(--color-muted)] mb-3">Zona horaria</p>
          <p class="text-sm">CST (Monterrey, México)</p>

          <p class="uppercase tracking-[0.25em] text-[var(--color-muted)] mb-3 mt-6">Idiomas</p>
          <p class="text-sm">Español · English</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
