---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto" description="Contacto de Von Diego.">
  <section class="author-meta-row">
    <a href="/" class="hover:text-[var(--color-accent)] transition-colors">← archivo</a>
    <span>contacto / ficha</span>
    <span>respuesta en días hábiles</span>
  </section>

  <section class="author-statement">
    <div>
      <p class="micro-label text-[var(--color-accent)]">ficha de contacto</p>
      <h1 class="author-title">La puerta no está escondida.</h1>
    </div>
    <div class="author-statement-copy">
      <p>
        Una dirección basta. Lo demás se habla si hace falta.
      </p>
      <p>
        No hay formulario. No hay embudo. No hay teatro.
      </p>
    </div>
  </section>

  <section class="author-contact-mail">
    <p class="micro-label text-[var(--color-muted)]">correo</p>
    <a href="mailto:contacto@vondiego.com">contacto@vondiego.com</a>
  </section>

  <section class="author-process">
    {[
      ['01', 'mensaje', 'lo suficiente para abrir la conversación'],
      ['02', 'silencio', 'lo que no sirve se queda afuera'],
      ['03', 'respuesta', 'si hay algo que decir, se dice'],
    ].map(([num, title, copy]) => (
      <div>
        <span>{num}</span>
        <h3>{title}</h3>
        <p>{copy}</p>
      </div>
    ))}
  </section>
</BaseLayout>
